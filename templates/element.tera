    "--cpd-color-bg-canvas-default-level-1": "#{{ mantle.hex }}",
    "--cpd-color-bg-canvas-disabled": "#{{ mantle.hex }}",
    "--cpd-color-bg-subtle-secondary-level-0": "#{{ crust.hex }}",
    "--cpd-color-bg-action-primary-disabled": "#{{ overlay0.hex }}",
    "--cpd-color-bg-action-secondary-rest": "#{{ base.hex }}",
    "--cpd-color-bg-action-tertiary-rest": "#{{ base.hex }}",
    "--cpd-color-bg-action-tertiary-hovered": "#{{ surface0.hex }}",
    "--cpd-color-bg-action-tertiary-selected": "#{{ surface1.hex }}",
    "--cpd-color-bg-critical-primary": "#{{ red.hex }}",
    "--cpd-color-bg-critical-hovered": "#{{ red | mix(color=text, amount=0.85) | hex }}",
    "--cpd-color-bg-critical-subtle": "#{{ red | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-bg-success-subtle": "#{{ green | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-bg-info-subtle": "#{{ blue | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-bg-accent-rest": "#{{ a.hex }}",
    "--cpd-color-bg-accent-hovered": "#{{ a | mix(color=overlay0, amount=0.65) | hex }}",
    "--cpd-color-bg-accent-pressed": "#{{ a | mix(color=overlay0, amount=0.50) | hex }}",
    "--cpd-color-bg-accent-selected": "#{{ a | mix(color=crust, amount=0.25) | hex }}",
    "--cpd-color-bg-decorative-1": "#{{ green | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-bg-decorative-2": "#{{ sky | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-bg-decorative-3": "#{{ pink | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-bg-decorative-4": "#{{ mauve | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-bg-decorative-5": "#{{ red | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-bg-decorative-6": "#{{ peach | mix(color=crust, amount=0.22) | hex }}",

    "--cpd-color-icon-primary": "#{{ text.hex }}",
    "--cpd-color-icon-secondary": "#{{ subtext0.hex }}",
    "--cpd-color-icon-tertiary": "#{{ overlay1.hex }}",
    "--cpd-color-icon-quaternary": "#{{ overlay0.hex }}",
    "--cpd-color-icon-accent-primary": "#{{ a.hex }}",
    "--cpd-color-icon-critical-primary": "#{{ red.hex }}",
    "--cpd-color-icon-success-primary": "#{{ green.hex }}",
    "--cpd-color-icon-info-primary": "#{{ blue.hex }}",
    "--cpd-color-icon-on-solid-primary": "#{{ base.hex }}",
    "--cpd-color-icon-disabled": "#{{ surface2.hex }}",

    "--cpd-color-border-interactive-primary": "#{{ overlay2.hex }}",
    "--cpd-color-border-interactive-secondary": "#{{ overlay0.hex }}",
    "--cpd-color-border-interactive-hovered": "#{{ text.hex }}",
    "--cpd-color-border-disabled": "#{{ surface2.hex }}",
    "--cpd-color-border-focused": "#{{ a.hex }}",
    "--cpd-color-border-critical-primary": "#{{ red.hex }}",
    "--cpd-color-border-success-subtle": "#{{ green | mix(color=crust, amount=0.44) | hex }}",
    "--cpd-color-border-info-subtle": "#{{ blue | mix(color=crust, amount=0.44) | hex }}",
    "--cpd-color-border-accent-subtle": "#{{ surface2.hex }}"
  }
}
