---
whiskers:
  version: ^2.5.1
  matrix:
    - flavor
    - accent
  filename: "themes/{{ flavor.identifier }}/{{ accent }}.json"
---
{%- set a = flavor.colors[accent] -%}
{
  "name": "Catppuccin {{ flavor.name }} ({{ a.name }})",
  "is_dark": {{ flavor.dark }},
  "colors": {
    "accent-color": "#{{ a.hex }}",
    "primary-color": "#{{ a.hex }}",
    "warning-color": "#{{ red.hex }}",
    "alert": "#{{ yellow.hex }}",
    "sidebar-color": "#{{ crust.hex }}",
    "roomlist-background-color": "#{{ mantle.hex }}",
    "roomlist-text-color": "#{{ text.hex }}",
    "roomlist-text-secondary-color": "#{{ overlay2.hex }}",
    "roomlist-highlights-color": "#{{ surface1.hex }}",
    "roomlist-separator-color": "#{{ overlay1.hex }}",
    "timeline-background-color": "#{{ base.hex }}",
    "timeline-text-color": "#{{ text.hex }}",
    "secondary-content": "#{{ text.hex }}",
    "tertiary-content": "#{{ text.hex }}",
    "timeline-text-secondary-color": "#{{ subtext0.hex }}",
    "timeline-highlights-color": "#{{ mantle.hex }}",
    "reaction-row-button-selected-bg-color": "#{{ surface1.hex }}",
    "menu-selected-color": "#{{ surface1.hex }}",
    "focus-bg-color": "#{{ surface2.hex }}",
    "room-highlight-color": "#{{ sky.hex }}",
    "togglesw-off-color": "#{{ overlay2.hex }}",
    "other-user-pill-bg-color": "#{{ sky.hex }}",
    "username-colors": [
      "#{{ mauve.hex }}",
      "#{{ maroon.hex }}",
      "#{{ peach.hex }}",
      "#{{ green.hex }}",
      "#{{ teal.hex }}",
      "#{{ sky.hex }}",
      "#{{ sapphire.hex }}",
      "#{{ lavender.hex }}"
    ],
    "avatar-background-colors": [
      "#{{ blue.hex }}",
      "#{{ mauve.hex }}",
      "#{{ green.hex }}"
    ]
  },
  "compound": {
    "--cpd-color-theme-bg": "#{{ base.hex }}",
{% if flavor.dark %}
    "--cpd-color-gray-100": "#{{ crust.hex }}",
    "--cpd-color-gray-200": "#{{ mantle.hex }}",
    "--cpd-color-gray-300": "#{{ base.hex }}",
    "--cpd-color-gray-400": "#{{ surface0.hex }}",
    "--cpd-color-gray-500": "#{{ surface1.hex }}",
    "--cpd-color-gray-600": "#{{ surface2.hex }}",
    "--cpd-color-gray-700": "#{{ overlay0.hex }}",
    "--cpd-color-gray-800": "#{{ overlay1.hex }}",
    "--cpd-color-gray-900": "#{{ overlay2.hex }}",
    "--cpd-color-gray-1000": "#{{ subtext0.hex }}",
    "--cpd-color-gray-1100": "#{{ subtext1.hex }}",
    "--cpd-color-gray-1200": "#{{ text.hex }}",
    "--cpd-color-gray-1300": "#{{ text | mod(lightness=90) | hex }}",
    "--cpd-color-gray-1400": "#{{ text | mod(lightness=95) | hex }}",
{% else %}
    "--cpd-color-gray-100": "#{{ text | mod(lightness=95) | hex }}",
    "--cpd-color-gray-200": "#{{ text | mod(lightness=90) | hex }}",
    "--cpd-color-gray-300": "#{{ text.hex }}",
    "--cpd-color-gray-400": "#{{ subtext1.hex }}",
    "--cpd-color-gray-500": "#{{ subtext0.hex }}",
    "--cpd-color-gray-600": "#{{ overlay2.hex }}",
    "--cpd-color-gray-700": "#{{ overlay1.hex }}",
    "--cpd-color-gray-800": "#{{ overlay0.hex }}",
    "--cpd-color-gray-900": "#{{ surface2.hex }}",
    "--cpd-color-gray-1000": "#{{ surface1.hex }}",
    "--cpd-color-gray-1100": "#{{ surface0.hex }}",
    "--cpd-color-gray-1200": "#{{ base.hex }}",
    "--cpd-color-gray-1300": "#{{ mantle.hex }}",
    "--cpd-color-gray-1400": "#{{ crust.hex }}",
{% endif %}
{% if flavor.dark %}
    "--cpd-color-red-100": "#{{ red | mix(color=crust, amount=0.10) | hex }}",
    "--cpd-color-red-200": "#{{ red | mix(color=crust, amount=0.15) | hex }}",
    "--cpd-color-red-300": "#{{ red | mix(color=crust, amount=0.22) | hex }}",
    "--cpd-color-red-400": "#{{ red | mix(color=crust, amount=0.32) | hex }}",
    "--cpd-color-red-500": "#{{ red | mix(color=crust, amount=0.44) | hex }}",
    "--cpd-color-red-600": "#{{ red | mix(color=crust, amount=0.54) | hex }}",
    "--cpd-color-red-700": "#{{ red | mix(color=crust, amount=0.67) | hex }}",
    "--cpd-color-red-800": "#{{ red | mix(color=crust, amount=0.83) | hex }}",
    "--cpd-color-red-900": "#{{ red.hex }}",
    "--cpd-color-red-1000": "#{{ red | mix(color=text, amount=0.85) | hex }}",
    "--cpd-color-red-1100": "#{{ red | mix(color=text, amount=0.70) | hex }}",
    "--cpd-color-red-1200": "#{{ red | mix(color=text, amount=0.50) | hex }}",
    "--cpd-color-red-1300": "#{{ red | mix(color=text, amount=0.30) | hex }}",
    "--cpd-color-red-1400": "#{{ red | mix(color=text, amount=0.15) | hex }}",

    "--cpd-color-orange-100": "#{{ peach | mix(color=crust, amount=0.10) | hex }}",
    "--cpd-color-orange-200": "#{{ peach | mix(color=crust, amount=0.15) | hex }}",
    "--cpd-color-orange-300": "#{{ peach | mix(color=crust, amount=0.22) | hex }}",
